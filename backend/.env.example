PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host:5432/vocalweb?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# AI Providers (both free tier — no credit card required)
GEMINI_API_KEY=          # Google AI Studio: aistudio.google.com — gemini-2.0-flash (primary)
GROQ_API_KEY=            # Groq Console: console.groq.com — llama-3.3-70b-versatile (fallback)

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Published sites base URL
PUBLISHED_BASE_URL=https://sites.vocalweb.ai

# Razorpay
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Admin (comma-separated)
ADMIN_EMAILS=admin@vocalweb.ai

# Logging
LOG_LEVEL=info

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  clerkId          String?        @unique
  email            String         @unique
  name             String?
  image            String?
  plan             Plan           @default(FREE)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  websites         Website[]
  subscription     Subscription?
  payments         Payment[]

  @@map("users")
}

model Website {
  id                  String           @id @default(cuid())
  userId              String
  businessName        String
  transcript          String           @db.Text
  htmlContent         String?          @db.Text
  themeColor          String           @default("#18181b")
  sections            String[]
  status              WebsiteStatus    @default(GENERATING)
  liveUrl             String?
  slug                String?          @unique
  validationPassed    Boolean          @default(false)
  validationErrors    String[]
  regenerationCount   Int              @default(0)
  publishedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  validations         Validation[]
  regenerationLogs    RegenerationLog[]

  @@map("websites")
}

model Validation {
  id              String    @id @default(cuid())
  websiteId       String
  passed          Boolean
  errors          String[]
  warnings        String[]
  attemptNumber   Int       @default(1)
  checkedAt       DateTime  @default(now())

  website         Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@map("validations")
}

model RegenerationLog {
  id            String    @id @default(cuid())
  websiteId     String
  triggeredBy   String    @default("user")
  reason        String?
  success       Boolean
  createdAt     DateTime  @default(now())

  website       Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@map("regeneration_logs")
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String             @unique
  plan            Plan
  status          SubscriptionStatus @default(ACTIVE)
  razorpaySubId   String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean         @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  razorpayOrderId String?
  razorpayPaymentId String?
  amount          Int
  currency        String        @default("INR")
  status          PaymentStatus @default(PENDING)
  plan            Plan
  createdAt       DateTime      @default(now())

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model MonitoringLog {
  id          String    @id @default(cuid())
  websiteId   String?
  type        String
  status      String
  message     String?
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@map("monitoring_logs")
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum WebsiteStatus {
  GENERATING
  READY
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
}
